# Database Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=breakthrough

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice Agent IDs (optional - will use defaults if not set)
ELEVENLABS_AGENT_JAM=your_jam_agent_id_here
ELEVENLABS_AGENT_DEBATE=your_debate_agent_id_here
ELEVENLABS_AGENT_DISCUSSION=your_discussion_agent_id_here
ELEVENLABS_AGENT_READING=your_reading_agent_id_here
ELEVENLABS_AGENT_INTERVIEW=your_interview_agent_id_here
ELEVENLABS_AGENT_BUSINESS=your_business_agent_id_here
ELEVENLABS_AGENT_THERAPY=your_therapy_agent_id_here
ELEVENLABS_AGENT_SOCIAL=your_social_agent_id_here
ELEVENLABS_AGENT_GENERAL=your_general_agent_id_here

# Audio Processing
WHISPER_MODEL=base
SAMPLE_RATE=16000

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Security
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30