# ============================================
# BreakThrough Project Environment Variables
# ============================================
# This is the root .env.example for Docker Compose setup
# Copy this file to .env for local development with Docker
# For non-Docker setup, use backend/.env.example and frontend/.env.example

# ============================================
# Docker Compose Configuration
# ============================================
# Compose project name
COMPOSE_PROJECT_NAME=breakthrough

# ============================================
# Backend Service
# ============================================
# Backend port (exposed to host)
BACKEND_PORT=8000

# Backend internal port
BACKEND_INTERNAL_PORT=8000

# ============================================
# Frontend Service
# ============================================
# Frontend port (exposed to host)
FRONTEND_PORT=3000

# Frontend internal port
FRONTEND_INTERNAL_PORT=3000

# ============================================
# MongoDB Service
# ============================================
# MongoDB port (exposed to host)
MONGO_PORT=27017

# MongoDB root username
MONGO_INITDB_ROOT_USERNAME=admin

# MongoDB root password
MONGO_INITDB_ROOT_PASSWORD=changeme

# MongoDB database name
MONGO_INITDB_DATABASE=breakthrough

# MongoDB data volume path
MONGO_DATA_PATH=./data/mongodb

# ============================================
# Redis Service
# ============================================
# Redis port (exposed to host)
REDIS_PORT=6379

# Redis password (optional, leave empty for no password)
REDIS_PASSWORD=

# Redis data volume path
REDIS_DATA_PATH=./data/redis

# ============================================
# AI Services API Keys
# ============================================
# Google Gemini API Key
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API Key
# Get your key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ============================================
# Application Configuration
# ============================================
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode
DEBUG=true

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# Security
# ============================================
# Secret key for JWT tokens
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# ============================================
# Network Configuration
# ============================================
# Docker network name
NETWORK_NAME=breakthrough-network

# ============================================
# Volume Configuration
# ============================================
# Base path for all data volumes
DATA_BASE_PATH=./data

# Uploads directory
UPLOADS_PATH=./data/uploads

# Logs directory
LOGS_PATH=./data/logs
